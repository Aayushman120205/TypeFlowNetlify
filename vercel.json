{
  "version": 2,
  "public": true,
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/auth/:action",
      "destination": "/api/auth.js"
    },
    {
      "source": "/api/auth",
      "destination": "/api/auth.js"
    },
    {
      "source": "/api/sessions",
      "destination": "/api/sessions.js"
    },
    {
      "source": "/api/leaderboard",
      "destination": "/api/leaderboard.js"
    },
    {
      "source": "/api/health",
      "destination": "/api/health.js"
    },
    {
      "source": "/(.*\\.html)?",
      "destination": "/$1"
    }
  ]
}

